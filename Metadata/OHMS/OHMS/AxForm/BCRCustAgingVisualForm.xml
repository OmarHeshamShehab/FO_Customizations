	<Name>BCRCustAgingVisualForm</Name>
	<SourceCode>
		<Methods xmlns="">
			<Method>
				<Name>classDeclaration</Name>
				<Source><![CDATA[
[Form]
public class BCRCustAgingVisualForm extends FormRun
{
    Query vQuery;
}
]]></Source>
			</Method>
			<Method>
				<Name>init</Name>
				<Source><![CDATA[
    public void init()
    {
        super();
        vQuery = new Query(queryStr(BCRCustomerAgingwithBankQuery));
        if (!FromDate.dateValue())
        {
            FromDate.dateValue(DateTimeUtil::getToday(DateTimeUtil::getUserPreferredTimeZone()));
        }
        // NEW: default DSO Number to 90 (editable by user)
        if (!DsoNumber.value())
        {
            DsoNumber.value(90);
        }
        this.applyAndLoad();
    }

]]></Source>
			</Method>
			<Method>
				<Name>buildContract</Name>
				<Source><![CDATA[
    private BCRCustomerAgingwithBankContract buildContract()
    {
        BCRCustomerAgingwithBankContract c = new BCRCustomerAgingwithBankContract();
        c.ParmFromDate(FromDate.dateValue() ? FromDate.dateValue() : DateTimeUtil::getToday(DateTimeUtil::getUserPreferredTimeZone()));
        return c;
    }

]]></Source>
			</Method>
			<Method>
				<Name>applyAndLoad</Name>
				<Source><![CDATA[
    public void applyAndLoad()
    {
        // NEW: pass DSO Number (fallback 90) to the engine
        int dsoDays = int642int(DsoNumber.value());
        AgingVisual.loadData(this.buildContract(), vQuery, dsoDays ? dsoDays : 90);
    }

]]></Source>
			</Method>
		</Methods>
