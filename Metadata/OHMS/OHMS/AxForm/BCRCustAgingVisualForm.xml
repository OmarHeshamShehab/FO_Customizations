				<Methods>
					<Method>
						<Name>clicked</Name>
						<Source><![CDATA[
        public void clicked()
        {
            super();
            QueryRun qr = new QueryRun(vQuery);
            if (qr.prompt())
            {
                vQuery = qr.query();
            }
        }

]]></Source>
					</Method>
				</Methods>
			</Control>
